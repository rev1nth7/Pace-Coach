# PaceCoach — environment variables
# Copy to .env.local and fill in real values. NEVER commit .env.local.
# .env.local is gitignored; this .env.example is committed as documentation.

# --- Supabase (Step 2/3) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Strava API (Step 4) ---
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_REDIRECT_URI=http://localhost:3000/api/strava/callback

# --- OpenAI (Step 7) — SERVER-SIDE ONLY, never prefix with NEXT_PUBLIC_ ---
OPENAI_API_KEY=

# --- App ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Demo mode (Step 9) — SERVER-SIDE ONLY, never prefix with NEXT_PUBLIC_ ---
# Shared read-only demo account "Try the demo" signs into (no signup).
DEMO_EMAIL=demo@pacecoach.app
DEMO_PASSWORD=
# Shared secret guarding POST /api/demo/seed (send as the x-seed-secret header).
DEMO_SEED_SECRET=
